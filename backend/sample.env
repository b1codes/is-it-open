# Required Secrets
SECRET_KEY=generate-a-secure-secret-key-here
TOMTOM_API_KEY=your-tomtom-key

# Production Settings
DEBUG=0
ALLOWED_HOSTS=yourdomain.com,your-ec2-ip

# Database (Used by docker-compose.prod.yml)
POSTGRES_DB=isitopen_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure-db-password

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=0
CORS_ALLOWED_ORIGINS=http://your-frontend-domain.com

# GDAL / GEOS (Only needed if not using the Docker defaults)
# GDAL_LIBRARY_PATH=
# GEOS_LIBRARY_PATH=
